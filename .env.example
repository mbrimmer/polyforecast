# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Cost controls
MAX_DAILY_LLM_COST_USD=20.0
MAX_MONTHLY_LLM_COST_USD=300.0

# Database
# Production / cloud: Neon Postgres connection string (paste exactly what Neon gives you;
# config.py auto-rewrites the postgresql:// prefix to postgresql+psycopg:// for SQLAlchemy).
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/polyforecast?sslmode=require
#
# Local dev / tests: SQLite is fine and requires no setup.
DATABASE_URL=sqlite:///data/polyforecast.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | console

# Scanner config
SCANNER_LIQUIDITY_THRESHOLD_USD=50000
SCANNER_MIN_DAYS_TO_RESOLUTION=14
SCANNER_MAX_DAYS_TO_RESOLUTION=180

# Trading config (paper only in v0)
STARTING_BANKROLL_USD=10000
KELLY_FRACTION=0.25
EDGE_THRESHOLD_POINTS=0.05
MAX_POSITION_PCT_OF_BANKROLL=0.05
